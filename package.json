{
  "name": "titanclip",
  "version": "1.0.0",
  "description": "TitanClip - AI Company Orchestration Platform",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "tsc -p tsconfig.electron.json && electron .",
    "dev:native": "tsc -p tsconfig.electron.json && PAPERCLIP_STARTUP_MODE=native electron .",
    "build": "pnpm -r build",
    "build:ui-electron": "cd ui && ELECTRON_BUILD=true pnpm run build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build:all": "pnpm run build && pnpm run build:ui-electron && pnpm run build:electron",
    "start": "electron .",
    "dist": "pnpm run build:all && bash scripts/patch-server-modules.sh && electron-builder --mac && bash scripts/sign-mac.sh",
    "dist:win": "pnpm run build:all && electron-builder --win",
    "dist:linux": "pnpm run build:all && electron-builder --linux",
    "typecheck": "pnpm -r typecheck"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.4",
  "devDependencies": {
    "@types/node": "^20.10.0",
    "electron": "^33.0.0",
    "electron-builder": "^26.8.1",
    "typescript": "^5.7.3"
  },
  "pnpm": {
    "patchedDependencies": {
      "embedded-postgres@18.1.0-beta.16": "patches/embedded-postgres@18.1.0-beta.16.patch"
    }
  }
}
