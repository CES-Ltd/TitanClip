<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Required for Electron apps -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <!-- Required for spawning child processes (adapters) -->
    <key>com.apple.security.cs.allow-dyld-environment-variables</key>
    <true/>
    <!-- Required for network access (API calls, adapter communication) -->
    <key>com.apple.security.network.client</key>
    <true/>
    <!-- Required for file access (storage, backups) -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>
    <!-- Required for bundled Node.js + native modules (embedded postgres) -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
</dict>
</plist>
